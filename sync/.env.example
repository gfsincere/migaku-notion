# Copy to .env and fill in your values

# --- Migoku (the Go API server that exposes Migaku data locally) ---
MIGOKU_URL=http://localhost:8080

# Either set MIGOKU_API_KEY directly (after running `python sync.py login` once),
# or set email + password and the script will derive the key on each run.
MIGOKU_EMAIL=
MIGOKU_PASSWORD=
MIGOKU_API_KEY=

# --- Notion ---
# 1) Create an internal integration at https://www.notion.so/profile/integrations
# 2) Open the "Migaku Word List" page in Notion -> ... menu -> Connections -> add your integration
# 3) Paste the integration secret here:
NOTION_TOKEN=

# Page ID of the Migaku Vocab database (already created)
# This is the GUID portion of the database URL.
NOTION_DATABASE_ID=051c8d33a24d40c88b1ed4cc8340acea

# --- Sync options ---
SYNC_LANG=zh
# Statuses to include. Comma-separated. KNOWN, LEARNING, UNKNOWN, IGNORED, or ALL.
SYNC_STATUS=KNOWN,LEARNING
# How many difficult-words to fetch (for fail-rate enrichment)
SYNC_DIFFICULT_LIMIT=2000
